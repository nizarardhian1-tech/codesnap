<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/filesFragment">

    <fragment android:id="@+id/filesFragment"
        android:name="code.editor.mon.FilesFragment"
        android:label="Files">
        <action android:id="@+id/toEditor"
            app:destination="@id/editorFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
        <action android:id="@+id/toSearch"
            app:destination="@id/searchFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <fragment android:id="@+id/editorFragment"
        android:name="code.editor.mon.EditorFragment"
        android:label="Editor"/>

    <fragment android:id="@+id/searchFragment"
        android:name="code.editor.mon.SearchFragment"
        android:label="Search"/>

</navigation>
