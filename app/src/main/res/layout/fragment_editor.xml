<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="start" />

        <TextView
            android:id="@+id/tvModified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="@color/accent_orange"
            android:textSize="14sp"
            android:layout_marginStart="6dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Find in file bar (hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutFindBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/etFindInFile"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Find in file..."
            android:hintTextColor="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:background="@color/bg_input"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="textNoSuggestions" />

        <TextView
            android:id="@+id/tvFindCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnFindPrev"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="↑"
            android:textColor="@color/accent"
            android:padding="0dp" />

        <Button
            android:id="@+id/btnFindNext"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="↓"
            android:textColor="@color/accent"
            android:padding="0dp" />

        <Button
            android:id="@+id/btnCloseFindBar"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="✕"
            android:textColor="@color/text_secondary"
            android:padding="0dp" />

    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvNoFile"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/editor_no_file"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp" />

    <!-- Code editor -->
    <ScrollView
        android:id="@+id/scrollEditor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:fillViewport="true">

        <EditText
            android:id="@+id/editCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:background="@color/bg_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="80dp"
            android:gravity="top|start"
            android:inputType="textMultiLine|textNoSuggestions"
            android:imeOptions="flagNoFullscreen"
            android:textCursorDrawable="@null" />

    </ScrollView>

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/layoutActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="2"
            android:layout_marginEnd="4dp"
            android:text="💾 Save"
            android:textSize="12sp"
            android:backgroundTint="@color/accent" />

        <Button
            android:id="@+id/btnUndo"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="↩ Undo"
            android:textColor="@color/text_primary"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnFind"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="🔍 Find"
            android:textColor="@color/accent"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnReplace"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:text="Replace"
            android:textColor="@color/accent_orange"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
