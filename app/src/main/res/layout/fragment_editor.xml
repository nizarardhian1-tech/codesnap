<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Back"/>

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="start"/>

        <TextView
            android:id="@+id/tvModified"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="●"
            android:textColor="@color/accent_orange"
            android:textSize="14sp"
            android:layout_marginEnd="4dp"
            android:visibility="gone"/>

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_undo"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Undo"/>

        <ImageButton
            android:id="@+id/btnFindToggle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_tab_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Find"/>

        <Button
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp"
            android:text="Save"
            android:textSize="12sp"
            android:backgroundTint="@color/accent"/>

    </LinearLayout>

    <!-- Find bar -->
    <LinearLayout
        android:id="@+id/layoutFindBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etFind"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Find..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="@color/bg_input"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:inputType="textNoSuggestions"/>

            <TextView
                android:id="@+id/tvFindCount"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"/>

            <ImageButton
                android:id="@+id/btnFindPrev"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_up"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent"
                android:contentDescription="Previous"/>

            <ImageButton
                android:id="@+id/btnFindNext"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_arrow_down"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/accent"
                android:contentDescription="Next"/>

            <ImageButton
                android:id="@+id/btnCloseFind"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/text_secondary"
                android:contentDescription="Close"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp">

            <EditText
                android:id="@+id/etReplace"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Replace with..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="@color/bg_input"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:singleLine="true"
                android:inputType="textNoSuggestions"/>

            <Button
                android:id="@+id/btnReplaceOne"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="6dp"
                android:text="1"
                android:textColor="@color/accent"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnReplaceAll"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="4dp"
                android:text="All"
                android:textSize="12sp"
                android:backgroundTint="@color/accent"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Line info bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvLineInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tvFileExt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent"
            android:textSize="10sp"/>

    </LinearLayout>

    <!-- Code editor -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <ScrollView
            android:id="@+id/scrollEditor"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <EditText
                android:id="@+id/editCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:background="@color/bg_primary"
                android:paddingStart="12dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="60dp"
                android:gravity="top|start"
                android:inputType="textMultiLine|textNoSuggestions"
                android:imeOptions="flagNoFullscreen"
                android:textCursorDrawable="@null"
                android:minWidth="100dp"/>

        </ScrollView>

    </HorizontalScrollView>

</LinearLayout>
