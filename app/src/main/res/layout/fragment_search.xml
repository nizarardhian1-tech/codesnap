<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_secondary"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search in Project"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <!-- Search input -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_hint"
            android:hintTextColor="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:background="@color/bg_input"
            android:padding="10dp"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="2"
            android:maxLines="8"
            android:gravity="top|start"
            android:imeOptions="flagNoFullscreen" />

        <!-- Options row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbCaseSensitive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Case sensitive"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:buttonTint="@color/accent" />

            <CheckBox
                android:id="@+id/cbRegex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Regex"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:buttonTint="@color/accent" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <Button
                android:id="@+id/btnSearch"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Search"
                android:textSize="13sp"
                android:backgroundTint="@color/accent" />

        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvSearchStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/searchProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent"
        android:visibility="gone" />

    <!-- Placeholder -->
    <TextView
        android:id="@+id/tvSearchPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="@string/search_placeholder"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp" />

    <!-- Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:scrollbars="vertical" />

</LinearLayout>
