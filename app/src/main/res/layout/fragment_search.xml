<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_secondary"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Search in Project"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_secondary"
        android:padding="10dp">

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Paste or type code snippet..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:background="@color/bg_input"
            android:padding="10dp"
            android:inputType="textMultiLine|textNoSuggestions"
            android:minLines="2"
            android:maxLines="6"
            android:gravity="top|start"
            android:imeOptions="flagNoFullscreen"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/cbCaseSensitive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aa"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:buttonTint="@color/accent"/>

            <CheckBox
                android:id="@+id/cbRegex"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text=".*"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:buttonTint="@color/accent"/>

            <CheckBox
                android:id="@+id/cbWholeWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="\b"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:buttonTint="@color/accent"/>

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <Button
                android:id="@+id/btnSearch"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Search"
                android:textSize="12sp"
                android:backgroundTint="@color/accent"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvSearchStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:paddingTop="4dp"
            android:visibility="gone"/>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/searchProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:indeterminateTint="@color/accent"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Open a project, then search for any code snippet."
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:padding="32dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:scrollbars="vertical"/>

</LinearLayout>
